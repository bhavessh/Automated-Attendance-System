# Environment Variables Template
# Copy this file to .env and update with your actual values

# Database Configuration
POSTGRES_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql://attendance_user:your_secure_database_password_here@localhost:5432/attendance_system

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:your_secure_redis_password_here@localhost:6379/0

# Flask Application Security
SECRET_KEY=your_very_secure_secret_key_minimum_32_characters_long
JWT_SECRET_KEY=your_jwt_secret_key_for_token_signing
ENCRYPTION_KEY=your_32_character_fernet_encryption_key_here

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=false

# Face Recognition Settings
FACE_RECOGNITION_TOLERANCE=0.6
FACE_RECOGNITION_MODEL=hog
FACE_RECOGNITION_NUM_JITTERS=1

# File Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# JWT Token Settings
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Power BI Integration (Optional)
POWERBI_CLIENT_ID=your_powerbi_application_client_id
POWERBI_CLIENT_SECRET=your_powerbi_application_client_secret
POWERBI_TENANT_ID=your_azure_ad_tenant_id
POWERBI_WORKSPACE_ID=your_powerbi_workspace_id

# Email Configuration for Notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@domain.com
MAIL_PASSWORD=your_email_app_password
MAIL_DEFAULT_SENDER=attendance-system@school.edu

# Admin Contact Information
ADMIN_EMAIL=admin@school.edu
SUPPORT_EMAIL=support@school.edu

# Security Settings
BCRYPT_LOG_ROUNDS=12
SESSION_TIMEOUT=1800
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/attendance

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_FILE_SIZE=10MB
LOG_BACKUP_COUNT=5

# Camera and Recognition Settings
CAMERA_RESOLUTION_WIDTH=1280
CAMERA_RESOLUTION_HEIGHT=720
CAMERA_FPS=30
RECOGNITION_INTERVAL=2
MAX_FACES_PER_FRAME=10

# Performance Settings
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
REQUEST_TIMEOUT=30
KEEPALIVE_TIMEOUT=2

# SSL/TLS Configuration (if using HTTPS)
SSL_KEYFILE=ssl/private.key
SSL_CERTFILE=ssl/certificate.crt

# Development Settings (set to false in production)
DEBUG_MODE=false
TESTING=false

# Docker-specific settings
COMPOSE_PROJECT_NAME=attendance-system

# Monitoring and Alerting
ENABLE_PERFORMANCE_MONITORING=true
ALERT_EMAIL_RECIPIENTS=admin@school.edu,tech@school.edu
ALERT_HIGH_CPU_THRESHOLD=90
ALERT_HIGH_MEMORY_THRESHOLD=85
ALERT_LOW_DISK_THRESHOLD=10

# External API Keys (if needed)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string

# Timezone and Localization
DEFAULT_TIMEZONE=UTC
DEFAULT_LANGUAGE=en
DATE_FORMAT=YYYY-MM-DD
TIME_FORMAT=HH:mm:ss

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Cache Settings
CACHE_DEFAULT_TIMEOUT=300
CACHE_THRESHOLD=500

# File Storage Settings
STATIC_FILE_PATH=/app/static
UPLOAD_FILE_PATH=/app/uploads
TEMP_FILE_PATH=/tmp

# Network Settings
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Database Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Health Check Settings
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# Backup Encryption
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_32_chars