# Environment variables for the Automated Attendance System

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost/attendance_db

# Security Keys
SECRET_KEY=your-very-secure-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# Face Recognition Settings
FACE_RECOGNITION_TOLERANCE=0.6
FACE_RECOGNITION_MODEL=hog
MAX_FACES_PER_STUDENT=5

# File Upload Settings
UPLOAD_FOLDER=uploads/faces
MAX_CONTENT_LENGTH=16777216

# API Settings
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=True

# Power BI Integration
POWERBI_WORKSPACE_ID=your-powerbi-workspace-id
POWERBI_DATASET_ID=your-powerbi-dataset-id
POWERBI_CLIENT_ID=your-powerbi-client-id
POWERBI_CLIENT_SECRET=your-powerbi-client-secret

# Email/SMS Settings (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SMS_API_KEY=your-sms-api-key

# System Settings
TIMEZONE=UTC
ATTENDANCE_WINDOW_MINUTES=15
MAX_STUDENTS_PER_CLASS=50
OFFLINE_SYNC_INTERVAL=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log